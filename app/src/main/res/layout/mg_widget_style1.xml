<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_car_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MG7"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_plate_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="2dp"
            android:text="川G"
            android:textColor="@color/widget_text_color"
            android:textSize="12sp" />
    </LinearLayout>



    <LinearLayout
        android:id="@+id/ll_total_range"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll_header"
        android:gravity="bottom"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="20dp"
            android:layout_marginBottom="7dp"
            android:src="@drawable/range"
            android:tint="@color/widget_text_color" />

        <TextView
            android:id="@+id/tv_total_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="422"
            android:textColor="@color/widget_text_color"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginBottom="4dp"
            android:text="km"
            android:textColor="@color/widget_text_color"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_energy_split"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll_total_range"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="3dp"
            android:src="@drawable/battery" />

        <TextView
            android:id="@+id/tv_ev_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="110"
            android:textColor="@color/widget_text_color"
            android:textSize="14sp"
            android:textStyle="bold" />


        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="3dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/fuel" />

        <TextView
            android:id="@+id/tv_fuel_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="312"
            android:textColor="@color/widget_text_color"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_info_grid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll_energy_split"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/odometer" />

            <TextView
                android:id="@+id/tv_total_mileage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="17813 km"
                android:textColor="@color/widget_text_color"
                android:textSize="12sp" />


            <ImageView
                android:layout_width="12dp"
                android:layout_height="16dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/tempgreen" />

            <TextView
                android:id="@+id/tv_temp_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="13°C"
                android:textColor="@color/status_green"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/batteryvoltage" />

            <TextView
                android:id="@+id/tv_battery_voltage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="12.4 V"
                android:textColor="@color/widget_text_color"
                android:textSize="12sp" />


            <ImageView
                android:layout_width="24dp"
                android:layout_height="26dp"
                android:layout_marginRight="-4dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/detailspage_car" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_fl_p"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.5"
                        android:textColor="@color/widget_text_color"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_fr_p"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.4"
                        android:layout_marginStart="4dp"
                        android:textColor="@color/widget_text_color"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_rl_p"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.5"
                        android:textColor="@color/widget_text_color"
                        android:textSize="10sp" />


                    <TextView
                        android:id="@+id/tv_rr_p"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.5"
                        android:layout_marginStart="4dp"
                        android:textColor="@color/widget_text_color"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_car_image"
        android:layout_width="140dp"
        android:layout_height="90dp"
        android:layout_alignParentEnd="true"
        android:scaleType="fitCenter"
        android:layout_marginBottom="-20dp"
        android:src="@drawable/blue_mg7" />

    <LinearLayout
        android:id="@+id/ll_status_badges"
        android:layout_width="140dp"
        android:layout_height="20dp"
        android:layout_below="@id/iv_car_image"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_lock_badge"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_launcher_background"
            android:backgroundTint="#E8F5E9"
            android:text="🔒 已锁"
            android:textColor="@color/status_green"
            android:textSize="11sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/tv_window_badge"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_launcher_background"
            android:backgroundTint="#E8F5E9"
            android:text="✅ 门窗关"
            android:textColor="@color/status_green"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:textStyle="bold" />
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">

        <ImageView
            android:id="@+id/iv_loc_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_centerVertical="true"
            android:src="@drawable/addr" />

        <TextView
            android:id="@+id/tv_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:layout_toStartOf="@id/tv_update_time"
            android:layout_toEndOf="@id/iv_loc_icon"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="四川省成都市温江区鹏程路1519号合能珍宝琥珀"
            android:textColor="@color/widget_text_color"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/iv_update_time"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="6dp"
            android:src="@drawable/update" />

        <TextView
            android:id="@+id/tv_update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/iv_update_time"
            android:text="09:51"
            android:textSize="12sp"
            android:textColor="@color/widget_text_color"/>
    </RelativeLayout>

</RelativeLayout>